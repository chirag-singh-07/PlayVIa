{
  "expo": {
    "name": "PlayVia",
    "slug": "playvia",
    "version": "1.0.0",
    "cli": {
  "appVersionSource": "remote"
},
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.rudnex.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
"plugins": [
  "expo-localization",
  [
    "expo-build-properties",
    {
      "android": {
        "compileSdkVersion": 35,
        "targetSdkVersion": 35,
        "buildToolsVersion": "35.0.0",
        "kotlinVersion": "2.0.21",
        "minSdkVersion": 24
      }
    }
  ],
  "expo-secure-store"
],
    "extra": {
      "eas": {
        "projectId": "402a06e8-d05f-481f-b2e9-de4aebfabef5"
      }
    }
  }
}
