{
  "expo": {
    "name": "PlayVia",
    "slug": "playvia",
    "scheme": "playvia",
    "version": "1.1.14",
    "cli": {
      "appVersionSource": "local"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 27,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.rudnex.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "newArchEnabled": false,
            "packagingOptions": {
              "jniLibs": {
                "useLegacyPackaging": false
              }
            }
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-secure-store",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4867895597149993~9493013109",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delay_app_measurement_init": true,
          "user_tracking_usage_description": "This identifier will be used to show personalised ads to you."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "402a06e8-d05f-481f-b2e9-de4aebfabef5"
      }
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-4867895597149993~9493013109",
    "ios_app_id": "ca-app-pub-3940256099942544~1458002511"
  }
}
